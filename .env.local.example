# Local development overrides for OCTO Drone Shop.
# Usage:
#   cp .env.example .env.local
#   edit .env.local with local values

APP_NAME=octo-drone-shop-local
OTEL_SERVICE_NAME=octo-drone-shop-local
OBSERVABILITY_APP_NAME=
OBSERVABILITY_SERVICE_NAME=
APP_RUNTIME=docker
ENVIRONMENT=development
PORT=8080
OCI_AUTH_MODE=auto
SEED_USER_EMAIL_DOMAIN=example.invalid
SEED_PAGEVIEW_IP_PREFIX=198.18.0.

# Oracle ATP connection (required)
ORACLE_DSN=
ORACLE_USER=ADMIN
ORACLE_PASSWORD=
ORACLE_WALLET_DIR=/opt/oracle/wallet
ORACLE_WALLET_PASSWORD=
ORACLE_WALLET_PATH=./wallet

# Optional integrations
ENTERPRISE_CRM_URL=
OCI_COMPARTMENT_ID=
OCI_GENAI_ENDPOINT=
OCI_GENAI_MODEL_ID=
WORKFLOW_API_BASE_URL=http://localhost:8090
WORKFLOW_SERVICE_NAME=octo-workflow-gateway
WORKFLOW_POLL_SECONDS=90
WORKFLOW_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
WORKFLOW_FAULTY_QUERY_ENABLED=false
SELECTAI_PROFILE_NAME=

# Optional observability
OCI_APM_ENDPOINT=
OCI_APM_PRIVATE_DATAKEY=
OCI_APM_PUBLIC_DATAKEY=
OCI_APM_RUM_ENDPOINT=
OCI_APM_WEB_APPLICATION=octo-drone-shop-web
OCI_LOG_ID=
OCI_LOG_GROUP_ID=
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# Optional auth hardening
# Required when ENVIRONMENT=production. In dev a per-process random secret
# is generated automatically with a warning log.
AUTH_TOKEN_SECRET=

# IDCS / OCI IAM Identity Domain (OIDC SSO) — leave blank to disable SSO
IDCS_DOMAIN_URL=
IDCS_CLIENT_ID=
IDCS_CLIENT_SECRET=
IDCS_REDIRECT_URI=http://localhost:8080/api/auth/sso/callback
IDCS_SCOPE=openid profile email
IDCS_POST_LOGOUT_REDIRECT=http://localhost:8080/login
IDCS_VERIFY_JWT=true
