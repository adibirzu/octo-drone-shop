# OCTO Drone Shop shared environment template
# Copy to .env.local for local runs. Do not commit real secrets.

# Application
APP_NAME=octo-drone-shop
OTEL_SERVICE_NAME=octo-drone-shop-oke
OBSERVABILITY_APP_NAME=
OBSERVABILITY_SERVICE_NAME=
APP_RUNTIME=oke
ENVIRONMENT=production
PORT=8080
OCI_AUTH_MODE=instance_principal
AUTH_TOKEN_SECRET=
SEED_USER_EMAIL_DOMAIN=example.invalid
SEED_PAGEVIEW_IP_PREFIX=198.18.0.

# Oracle ATP
ORACLE_DSN=
ORACLE_USER=ADMIN
ORACLE_PASSWORD=
ORACLE_WALLET_DIR=/opt/oracle/wallet
ORACLE_WALLET_PASSWORD=
ORACLE_WALLET_PATH=./wallet

# Integrations
ENTERPRISE_CRM_URL=
OCI_COMPARTMENT_ID=
OCI_GENAI_ENDPOINT=
OCI_GENAI_MODEL_ID=

# OCI APM / RUM
OCI_APM_ENDPOINT=
OCI_APM_PRIVATE_DATAKEY=
OCI_APM_PUBLIC_DATAKEY=
OCI_APM_RUM_ENDPOINT=
OCI_APM_WEB_APPLICATION=octo-drone-shop-web

# Logging
OCI_LOG_ID=
OCI_LOG_GROUP_ID=
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
