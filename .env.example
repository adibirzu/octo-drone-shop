# OCTO Drone Shop shared environment template
# Copy to .env.local for local runs. Do not commit real secrets.

# Application
APP_NAME=octo-drone-shop
OTEL_SERVICE_NAME=octo-drone-shop-oke
OBSERVABILITY_APP_NAME=
OBSERVABILITY_SERVICE_NAME=
APP_RUNTIME=oke
ENVIRONMENT=production
PORT=8080
OCI_AUTH_MODE=instance_principal
AUTH_TOKEN_SECRET=
SEED_USER_EMAIL_DOMAIN=example.invalid
SEED_PAGEVIEW_IP_PREFIX=198.18.0.

# Oracle ATP
ORACLE_DSN=
ORACLE_USER=ADMIN
ORACLE_PASSWORD=
ORACLE_WALLET_DIR=/opt/oracle/wallet
ORACLE_WALLET_PASSWORD=
ORACLE_WALLET_PATH=./wallet

# Integrations
ENTERPRISE_CRM_URL=
OCI_COMPARTMENT_ID=
OCI_GENAI_ENDPOINT=
OCI_GENAI_MODEL_ID=
WORKFLOW_API_BASE_URL=
WORKFLOW_SERVICE_NAME=octo-workflow-gateway
WORKFLOW_POLL_SECONDS=90
WORKFLOW_ALLOWED_ORIGINS=https://shop.octodemo.cloud,https://crm.octodemo.cloud
WORKFLOW_FAULTY_QUERY_ENABLED=false
SELECTAI_PROFILE_NAME=

# OCI APM / RUM
OCI_APM_ENDPOINT=
OCI_APM_PRIVATE_DATAKEY=
OCI_APM_PUBLIC_DATAKEY=
OCI_APM_RUM_ENDPOINT=
OCI_APM_WEB_APPLICATION=octo-drone-shop-web

# OCI Console Drilldown URLs (360 Monitoring dashboard links)
APM_CONSOLE_URL=
OPSI_CONSOLE_URL=
DB_MANAGEMENT_CONSOLE_URL=
LOG_ANALYTICS_CONSOLE_URL=

# IDCS / OCI IAM Identity Domain (OIDC SSO)
# In a new tenancy: register a "Confidential Application" in the IAM domain,
# enable Authorization Code grant + scopes openid/profile/email, and copy the
# values below from the application's "OAuth configuration" tab.
IDCS_DOMAIN_URL=
IDCS_CLIENT_ID=
IDCS_CLIENT_SECRET=
IDCS_REDIRECT_URI=https://shop.octodemo.cloud/api/auth/sso/callback
IDCS_SCOPE=openid profile email
IDCS_POST_LOGOUT_REDIRECT=https://shop.octodemo.cloud/login
# Set to "false" only in air-gapped dev where the JWKS endpoint is unreachable
IDCS_VERIFY_JWT=true

# Tenancy-portable load balancer subnet (used by deploy/k8s/deployment.yaml)
OCI_LB_SUBNET_OCID=

# Logging
OCI_LOG_ID=
OCI_LOG_GROUP_ID=
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
OTLP_LOG_EXPORT_ENABLED=false
