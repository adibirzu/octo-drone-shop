{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2020"],
    "outDir": ".tsc-out",
    "noEmit": true
  },
  "include": ["tests/**/*.ts", "playwright.config.ts"]
}
