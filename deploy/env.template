# ============================================================================
# Octo Drone Shop — tenancy-portable environment template
# Copy to `.env` and fill. Never commit `.env`.
# ============================================================================

# ---- Public domains (frontends) ----
SHOP_DOMAIN=shop.octodemo.cloud
CRM_DOMAIN=crm.octodemo.cloud
OPS_DOMAIN=ops.octodemo.cloud
COORDINATOR_DOMAIN=coordinator.octodemo.cloud

# ---- OCI tenancy ----
OCI_REGION=eu-frankfurt-1
OCI_TENANCY_OCID=
OCI_COMPARTMENT_OCID=

# ---- OCI Logging ----
OCI_LOG_GROUP_SHOP=
OCI_LOG_GROUP_CRM=
OCI_LOG_GROUP_WAF=
OCI_LOG_GROUP_CHAOS_AUDIT=

# ---- OCI APM ----
OCI_APM_DOMAIN_OCID=
OCI_APM_PUBLIC_KEY=
OCI_APM_PRIVATE_KEY=
OCI_APM_UPLOAD_ENDPOINT=

# ---- OCI Log Analytics ----
OCI_LA_NAMESPACE=
OCI_LA_LOG_GROUP_OCID=

# ---- OCI WAF ----
OCI_WAF_POLICY_OCID_SHOP=
OCI_WAF_POLICY_OCID_CRM=
OCI_WAF_POLICY_OCID_OPS=
WAF_MODE=DETECTION

# ---- Secrets / Vault ----
OCI_VAULT_OCID=
OCI_KMS_KEY_OCID=

# ---- Database (Oracle ATP) ----
DB_TNS_NAME=
DB_WALLET_SECRET_OCID=
DB_USER_SECRET_OCID=
DB_PASSWORD_SECRET_OCID=

# ---- Chaos control ----
# Shop is READER only. Writes forbidden on shop surface.
# CRM + OPS are only controllers.
CHAOS_ENABLED=false
CHAOS_STATE_BACKEND=db           # db | object_storage
CHAOS_STATE_BUCKET=octo-chaos-state
CHAOS_STATE_POLL_SECONDS=10
CHAOS_MAX_TTL_SECONDS=3600

# ---- Feature flags ----
AUTOREMEDIATE_ENABLED=false
LA_ENRICHMENT_V2=true

# ---- Security ----
CORS_ALLOWED_ORIGINS=https://shop.octodemo.cloud,https://crm.octodemo.cloud,https://ops.octodemo.cloud
SESSION_COOKIE_SECURE=true
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_ADMIN_PER_MIN=30
CSP_REPORT_URI=

# ---- Cross-service identity ----
SERVICE_NAME_SHOP=octo-drone-shop
SERVICE_NAME_CRM=octo-enterprise-crm
SERVICE_NAME_COORDINATOR=oci-coordinator
